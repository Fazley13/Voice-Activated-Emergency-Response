<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.codevengers.voiceemergency.EmergencyContactsController">
    <top>
        <VBox style="-fx-background-color: #2C3E50;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 20;">
                    <children>
                        <Text fx:id="userNameLabel" fill="WHITE" text="Emergency Contacts">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Text>
                        <Region HBox.hgrow="ALWAYS" />
                        <Text fx:id="contactCountLabel" fill="#BDC3C7" text="Total Contacts: 0">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Text>
                        <Button fx:id="addContactBtn" onAction="#showAddContactForm" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="+ Add Contact" />
                        <Button fx:id="backToDashboardBtn" onAction="#backToDashboard" style="-fx-background-color: #3498DB; -fx-text-fill: white;" text="← Back to Dashboard" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <VBox spacing="20.0" style="-fx-padding: 20;">
            <children>
                <!-- Add/Edit Contact Form -->
                <VBox fx:id="addContactForm" spacing="15.0" style="-fx-background-color: #ECF0F1; -fx-padding: 20; -fx-background-radius: 10;" visible="false">
                    <children>
                        <Text fx:id="formTitleText" text="Add New Emergency Contact">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Text>

                        <GridPane hgap="15.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="Name *:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="nameField" promptText="Enter contact name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Phone Number *:" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="phoneField" promptText="e.g., 01700000000" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="emailField" promptText="email@example.com (optional)" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Relationship *:" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="relationshipCombo" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Primary Contact:" GridPane.columnIndex="0" GridPane.rowIndex="4">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <CheckBox fx:id="primaryCheckBox" text="Set as primary emergency contact" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="cancelBtn" onAction="#hideAddContactForm" style="-fx-background-color: #95A5A6; -fx-text-fill: white;" text="Cancel" />
                                <Button fx:id="saveContactBtn" onAction="#saveContact" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="Save Contact" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Emergency Contacts Table -->
                <VBox spacing="10.0">
                    <children>
                        <Text text="Your Emergency Contacts">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Text>

                        <TableView fx:id="contactsTable" prefHeight="400.0">
                            <columns>
                                <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name" />
                                <TableColumn fx:id="phoneColumn" prefWidth="130.0" text="Phone" />
                                <TableColumn fx:id="emailColumn" prefWidth="180.0" text="Email" />
                                <TableColumn fx:id="relationshipColumn" prefWidth="120.0" text="Relationship" />
                                <TableColumn fx:id="primaryColumn" prefWidth="80.0" text="Primary" />
                                <TableColumn fx:id="actionsColumn" prefWidth="150.0" text="Actions" />
                            </columns>
                            <placeholder>
                                <Label text="No emergency contacts added yet. Click 'Add Contact' to get started." />
                            </placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>