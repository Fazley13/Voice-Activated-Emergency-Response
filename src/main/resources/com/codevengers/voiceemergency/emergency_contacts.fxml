<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:controller="EmergencyContactsController"
      xmlns:fx="http://javafx.com/fxml"
      alignment="TOP_CENTER"
      spacing="15.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Your Emergency Contacts" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <VBox fx:id="contactBox" spacing="5.0" />

    <Button fx:id="closeButton" text="Close" />
</VBox>
