<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.codevengers.voiceemergency.PanicButtonController"
      alignment="CENTER"
      spacing="20"
      prefWidth="300"
      prefHeight="200">

    <Button text="🚨 Panic Button"
            fx:id="panicButton"
            onAction="#handlePanicButtonClick"
            style="-fx-font-size: 18px; -fx-background-color: red; -fx-text-fill: white;"/>

</VBox>
