<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>

<!-- ✅ FIXED: Added full package name for controller -->
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.codevengers.voiceemergency.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29 0%, #302b63 50%, #24243e 100%);">

    <!-- Navigation Header -->
    <top>
        <HBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 20 40;" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                    <image>
                        <!-- ✅ FIXED: Added proper absolute path for image -->
                        <Image url="@/com/codevengers/voiceemergency/sound-sensor.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="QuickRescue" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Voice Activated Emergency Response" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Login" onAction="#showLoginOptions"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; 
                               -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 20; -fx-padding: 8 20;"/>
                <Button text="Get Started" onAction="#showRegisterOptions"
                        style="-fx-background-color: linear-gradient(to right, #ff6b6b, #ee5a24); -fx-text-fill: white; 
                               -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="0" alignment="TOP_CENTER">

                <!-- Hero Section -->
                <VBox alignment="CENTER" spacing="40" style="-fx-padding: 80 40 100 40; -fx-min-height: 600;">

                    <!-- Hero Content -->
                    <VBox alignment="CENTER" spacing="25" style="-fx-max-width: 800;">

                        <!-- Main Headline -->
                        <Label text="QuickRescue"
                               style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>

                        <Label text="Even in silence, we hear you"
                               style="-fx-font-size: 32px; -fx-text-fill: #ff6b6b; -fx-text-alignment: center; -fx-font-weight: bold;"/>

                        <!-- Subtitle -->
                        <Label text="Revolutionary voice-activated emergency response system that connects you to help instantly. When every second counts, your voice is your lifeline."
                               style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.9); -fx-text-alignment: center; 
                                      -fx-wrap-text: true; -fx-line-spacing: 5;"/>

                        <!-- CTA Buttons -->
                        <HBox spacing="25" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                            <Button fx:id="btnGetStarted" text="Start Your Journey" onAction="#showRegisterOptions"
                                    style="-fx-background-color: linear-gradient(to right, #ff6b6b, #ee5a24); 
                                           -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;
                                           -fx-padding: 18 35; -fx-background-radius: 25;
                                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 5);"/>

                            <Button text="Access Portal" onAction="#showLoginOptions"
                                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; 
                                           -fx-font-weight: bold; -fx-padding: 18 35; -fx-background-radius: 25;
                                           -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 2; -fx-border-radius: 25;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Features Section -->
                <VBox alignment="CENTER" spacing="60"
                      style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 100 40;">

                    <!-- Section Header -->
                    <VBox alignment="CENTER" spacing="15">
                        <Label text="Why Choose QuickRescue?"
                               style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                        <Label text="Advanced technology meets life-saving innovation"
                               style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.7); -fx-text-alignment: center;"/>
                    </VBox>

                    <!-- Features Grid -->
                    <HBox spacing="40" alignment="CENTER" style="-fx-max-width: 1200;">

                        <!-- Feature 1 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 300;">
                            <StackPane style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2); 
                                              -fx-background-radius: 60; -fx-pref-width: 120; -fx-pref-height: 120;
                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">
                                <Label text="MIC" style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                            </StackPane>
                            <Label text="Voice Activation"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                            <Label text="Simply speak to activate emergency protocols. No buttons, no delays - just your voice commanding immediate response."
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center; 
                                          -fx-wrap-text: true; -fx-line-spacing: 3;"/>
                        </VBox>

                        <!-- Feature 2 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 300;">
                            <StackPane style="-fx-background-color: linear-gradient(to bottom, #f093fb, #f5576c); 
                                              -fx-background-radius: 60; -fx-pref-width: 120; -fx-pref-height: 120;
                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">
                                <Label text="FAST" style="-fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                            </StackPane>
                            <Label text="Instant Response"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                            <Label text="Lightning-fast emergency contact notification system. Your emergency contacts are alerted within seconds of activation."
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center; 
                                          -fx-wrap-text: true; -fx-line-spacing: 3;"/>
                        </VBox>

                        <!-- Feature 3 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 300;">
                            <StackPane style="-fx-background-color: linear-gradient(to bottom, #4facfe, #00f2fe); 
                                              -fx-background-radius: 60; -fx-pref-width: 120; -fx-pref-height: 120;
                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">
                                <Label text="SAFE" style="-fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                            </StackPane>
                            <Label text="Secure and Reliable"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                            <Label text="Bank-level security with 99.9% uptime guarantee. Your safety data is encrypted and always protected."
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center; 
                                          -fx-wrap-text: true; -fx-line-spacing: 3;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- How It Works Section -->
                <VBox alignment="CENTER" spacing="60" style="-fx-padding: 100 40;">

                    <VBox alignment="CENTER" spacing="15">
                        <Label text="How It Works"
                               style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                        <Label text="Three simple steps to safety"
                               style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.7); -fx-text-alignment: center;"/>
                    </VBox>

                    <HBox spacing="60" alignment="CENTER">

                        <!-- Step 1 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 250;">
                            <StackPane>
                                <StackPane style="-fx-background-color: linear-gradient(to bottom, #ff9a9e, #fecfef); 
                                                  -fx-background-radius: 50; -fx-pref-width: 100; -fx-pref-height: 100;">
                                    <Label text="1" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                </StackPane>
                            </StackPane>
                            <Label text="Speak Command"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Say your emergency activation phrase"
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center;"/>
                        </VBox>

                        <!-- Step 2 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 250;">
                            <StackPane>
                                <StackPane style="-fx-background-color: linear-gradient(to bottom, #a8edea, #fed6e3); 
                                                  -fx-background-radius: 50; -fx-pref-width: 100; -fx-pref-height: 100;">
                                    <Label text="2" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                </StackPane>
                            </StackPane>
                            <Label text="System Activates"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="QuickRescue processes and verifies your emergency"
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center;"/>
                        </VBox>

                        <!-- Step 3 -->
                        <VBox alignment="CENTER" spacing="20" style="-fx-max-width: 250;">
                            <StackPane>
                                <StackPane style="-fx-background-color: linear-gradient(to bottom, #ffecd2, #fcb69f); 
                                                  -fx-background-radius: 50; -fx-pref-width: 100; -fx-pref-height: 100;">
                                    <Label text="3" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                </StackPane>
                            </StackPane>
                            <Label text="Help Arrives"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Emergency contacts and services are notified instantly"
                                   style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- CTA Section -->
                <VBox alignment="CENTER" spacing="40"
                      style="-fx-background-color: rgba(255,107,107,0.1); -fx-padding: 80 40;">

                    <VBox alignment="CENTER" spacing="20">
                        <Label text="Ready to Secure Your Safety?"
                               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white; -fx-text-alignment: center;"/>
                        <Label text="Join thousands who trust QuickRescue for their emergency response needs"
                               style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center;"/>
                    </VBox>

                    <HBox spacing="30" alignment="CENTER">
                        <Button text="Register as User" onAction="#handleUserRegisterClick"
                                style="-fx-background-color: linear-gradient(to bottom, #3498db, #2980b9); 
                                       -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;
                                       -fx-padding: 20 40; -fx-background-radius: 25;"/>

                        <Button text="Register as Admin" onAction="#handleAdminRegisterClick"
                                style="-fx-background-color: linear-gradient(to bottom, #e67e22, #d35400); 
                                       -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;
                                       -fx-padding: 20 40; -fx-background-radius: 25;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 25 40;" alignment="CENTER" spacing="40">
            <Label text="© 2024 QuickRescue - Voice Activated Emergency Response"
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="30">
                <Label text="Secure" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
                <Label text="Fast" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
                <Label text="Reliable" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>